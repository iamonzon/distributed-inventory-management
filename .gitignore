# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
dist/

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.out
coverage.html

# Go workspace file
go.work

# Dependency directories
vendor/

# SQLite database files
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp
*.log

# Build artifacts
cmd/service-a/service-a
cmd/service-b/service-b
cmd/demo/demo

# Root-level compiled binaries (protect against accidental commits)
/demo
/service-a
/service-b

# OS specific files
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Environment files (if you add them later)
.env
.env.local
.env.*.local

# Debug files
debug
__debug_bin

# Archive files (don't include zips in repo)
*.zip
*.tar.gz
*.tar
